{
	"info": {
		"name": "UPI Payment System",
		"description": "Complete API collection for UPI Payment System",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"firstname\": \"John\",\n  \"lastname\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"1234567890\",\n  \"password\": \"password123\"\n}"
						},
						"url": {"raw": "{{baseUrl}}/api/v1/auth/signup"}
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": ["var jsonData = JSON.parse(responseBody);", "pm.environment.set(\"token\", jsonData.token);"]
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [{"key": "Content-Type", "value": "application/json"}],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
						},
						"url": {"raw": "{{baseUrl}}/api/v1/auth/login"}
					}
				}
			]
		},
		{
			"name": "Wallet",
			"item": [
				{
					"name": "Get Wallet",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{baseUrl}}/api/v1/wallet"}
					}
				},
				{
					"name": "Get Balance",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{baseUrl}}/api/v1/wallet/balance"}
					}
				}
			]
		},
		{
			"name": "VPA",
			"item": [
				{
					"name": "Create VPA",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"Vpa\": \"john@paytm\",\n  \"isPrimary\": true\n}"
						},
						"url": {"raw": "{{baseUrl}}/api/v1/vpa"}
					}
				},
				{
					"name": "Get User VPAs",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{baseUrl}}/api/v1/vpa"}
					}
				},
				{
					"name": "Check VPA Availability",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{baseUrl}}/api/v1/vpa/check-availability?vpa=john@paytm"}
					}
				}
			]
		},
		{
			"name": "UPI PIN",
			"item": [
				{
					"name": "Set UPI PIN",
					"request": {
						"method": "POST",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{baseUrl}}/api/v1/upi-pin/set?upiPin=1234"}
					}
				},
				{
					"name": "Validate UPI PIN",
					"request": {
						"method": "POST",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{baseUrl}}/api/v1/upi-pin/validate?upiPin=1234"}
					}
				},
				{
					"name": "Change UPI PIN",
					"request": {
						"method": "POST",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{baseUrl}}/api/v1/upi-pin/change?oldPin=1234&newPin=5678"}
					}
				}
			]
		},
		{
			"name": "Transactions",
			"item": [
				{
					"name": "Send Money",
					"request": {
						"method": "POST",
						"header": [
							{"key": "Authorization", "value": "Bearer {{token}}"},
							{"key": "Content-Type", "value": "application/json"}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"recieverVpa\": \"friend@paytm\",\n  \"amount\": 500,\n  \"description\": \"Lunch money\",\n  \"upiPin\": \"1234\"\n}"
						},
						"url": {"raw": "{{baseUrl}}/api/v1/transaction/transfer"}
					}
				},
				{
					"name": "Get Transaction History",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{baseUrl}}/api/v1/transaction/history"}
					}
				},
				{
					"name": "Get Transaction by ID",
					"request": {
						"method": "GET",
						"header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
						"url": {"raw": "{{baseUrl}}/api/v1/transaction/UPI20250304123456ABC"}
					}
				}
			]
		}
	]
}
